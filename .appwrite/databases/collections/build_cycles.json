{
  "$id": "build_cycles",
  "name": "build_cycles",
  "enabled": true,
  "documentSecurity": false,
  "attributes": [
    {
      "key": "name",
      "type": "string",
      "size": 255,
      "required": true
    },
    {
      "key": "state",
      "type": "string",
      "size": 50,
      "required": true
    },
    {
      "key": "startDate",
      "type": "datetime",
      "required": true
    },
    {
      "key": "endDate",
      "type": "datetime",
      "required": true
    },
    {
      "key": "participantCount",
      "type": "integer",
      "required": false
    }
  ],
  "indexes": [
    {
      "key": "state",
      "type": "key",
      "attributes": ["state"],
      "orders": ["ASC"]
    },
    {
      "key": "startDate",
      "type": "key",
      "attributes": ["startDate"],
      "orders": ["DESC"]
    }
  ]
}

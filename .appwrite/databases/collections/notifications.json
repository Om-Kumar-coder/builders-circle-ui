      "type": "string",
      "size": 999,
      "required": true
    },
    {
      "key": "type",
      "type": "string",
      "size": 100,
      "required": true
    },
    {
      "key": "message",
      "type": "string",
      "size": 9999,
      "required": true
    },
    {
      "key": "read",
      "type": "boolean",
      "required": true
    },
    {
      "key": "metadata",
      "type": "string",
      "size": 9999,
      "required": false
    }
  ],
  "indexes": [
    {
      "key": "userId_read",
      "type": "key",
      "attributes": ["userId", "read"],
      "orders": ["DESC", "DESC"]
    },
    {
      "key": "userId",
      "type": "key",
      "attributes": ["userId"],
      "orders": ["DESC"]

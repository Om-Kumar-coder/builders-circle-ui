// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  profile              UserProfile?
  cycleParticipations  CycleParticipation[]
  activityEvents       ActivityEvent[]
  verifiedActivities   ActivityEvent[]      @relation("ActivityVerifier")
  ownershipLedger      OwnershipLedger[]
  multipliers          Multiplier[]
  notifications        Notification[]
  disputes             Dispute[]
  auditTrailAsAdmin    AuditTrail[]         @relation("AdminAuditTrail")
  auditTrailAsTarget   AuditTrail[]         @relation("TargetAuditTrail")
  systemLogs           SystemLog[]
  archivedActivities   ArchivedActivity[]

  @@map("users")
}

model UserProfile {
  id     String @id @default(cuid())
  userId String @unique
  role   String @default("contributor") // founder, admin, contributor, employee, observer
  status String @default("active") // active, suspended
  bio    String?
  avatar String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model BuildCycle {
  id               String   @id @default(cuid())
  name             String
  description      String?  // Optional description for the cycle
  state            String // planned, active, paused, closed
  startDate        DateTime
  endDate          DateTime
  participantCount Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relations
  participations   CycleParticipation[]
  activityEvents   ActivityEvent[]
  ownershipLedger  OwnershipLedger[]
  multipliers      Multiplier[]
  archivedActivities ArchivedActivity[]

  @@map("build_cycles")
}

model CycleParticipation {
  id                  String    @id @default(cuid())
  userId              String
  cycleId             String
  optedIn             Boolean   @default(true)
  participationStatus String // active, at-risk, paused, grace
  stallStage          String // none, grace, active, at_risk, diminishing, paused
  lastActivityDate    DateTime?
  createdAt           DateTime  @default(now())

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  cycle BuildCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)

  @@unique([userId, cycleId])
  @@map("cycle_participation")
}

model ActivityEvent {
  id                  String    @id @default(cuid())
  userId              String
  cycleId             String
  activityType        String    // code, documentation, review, task_completion, hours_logged, meeting, research
  proofLink           String
  description         String?
  hoursLogged         Float?    // Hours worked on this activity
  workSummary         String?   // Summary of work done
  taskReference       String?   // Reference to task/issue
  status              String    @default("pending") // pending, verified, rejected, changes_requested
  verifiedBy          String?   // Admin who verified/rejected
  verifiedAt          DateTime? // When verification happened
  rejectionReason     String?   // Reason for rejection/changes requested
  contributionType    String    @default("code") // code, documentation, review, hours_logged, meeting, research, task_completion
  contributionWeight  Float     @default(1.0)
  calculatedOwnership Float     @default(0.0)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  cycle      BuildCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  verifier   User?      @relation("ActivityVerifier", fields: [verifiedBy], references: [id])
  disputes   Dispute[]

  @@map("activity_events")
}

model OwnershipLedger {
  id                 String   @id @default(cuid())
  userId             String
  cycleId            String
  eventType          String
  ownershipAmount    Float
  multiplierSnapshot Float
  sourceReference    String?
  createdBy          String
  createdAt          DateTime @default(now())

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  cycle BuildCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)

  @@map("ownership_ledger")
}

model Multiplier {
  id         String   @id @default(cuid())
  userId     String
  cycleId    String
  multiplier Float
  reason     String?
  createdAt  DateTime @default(now())

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  cycle BuildCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)

  @@map("multipliers")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String // stall_warning, participation_paused, activity_verified, multiplier_changed, cycle_started, admin_message
  message   String
  read      Boolean  @default(false)
  metadata  String? // JSON string
  sent      Boolean  @default(false)
  createdAt DateTime @default(now())
  sentAt    DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model Dispute {
  id         String    @id @default(cuid())
  userId     String
  activityId String
  reason     String
  status     String    @default("pending") // pending, approved, denied
  resolution String?
  createdAt  DateTime  @default(now())
  resolvedAt DateTime?
  resolvedBy String?

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  activity ActivityEvent @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@map("disputes")
}

model AuditTrail {
  id            String   @id @default(cuid())
  adminId       String
  action        String // ownership_override, stall_clear, multiplier_restore, dispute_resolution
  targetUserId  String
  previousValue String? // JSON serialized
  newValue      String? // JSON serialized
  reason        String
  timestamp     DateTime @default(now())

  admin      User @relation("AdminAuditTrail", fields: [adminId], references: [id], onDelete: Cascade)
  targetUser User @relation("TargetAuditTrail", fields: [targetUserId], references: [id], onDelete: Cascade)

  @@map("audit_trail")
}

model ArchivedActivity {
  id                  String   @id @default(cuid())
  userId              String
  cycleId             String
  activityType        String
  proofLink           String
  description         String?
  verified            String
  contributionType    String   @default("code")
  contributionWeight  Float    @default(1.0)
  calculatedOwnership Float    @default(0.0)
  archivedAt          DateTime @default(now())
  originalId          String

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  cycle BuildCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)

  @@map("archived_activities")
}

model SystemLog {
  id        String   @id @default(cuid())
  event     String
  severity  String   @default("INFO") // DEBUG, INFO, WARNING, ERROR, CRITICAL
  message   String
  timestamp DateTime @default(now())
  userId    String?
  metadata  String? // JSON serialized

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("system_logs")
}